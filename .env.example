# Blockchain - Required for anchoring
PRIVATE_KEY=your_ethereum_private_key_without_0x_prefix
RPC_URL=https://polygon-rpc.com
POLYGON_RPC_URL=https://polygon-rpc.com

# IPFS - Required for manifest pinning (Pinata)
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_api_key

# Optional - Polygon Amoy testnet
# RPC_URL=https://rpc-amoy.polygon.technology

# Optional - For contract verification on Polygonscan
POLYGONSCAN_API_KEY=your_polygonscan_api_key

# Set after deploying HIKRegistry (from scripts/deploy.ts output)
HIK_REGISTRY_ADDRESS=
