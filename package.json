{
  "name": "human-is-kind-sdk",
  "version": "1.0.0",
  "description": "Blockchain-anchored provenance SDK for C2PA manifests",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "hardhat test",
    "test:blockchain": "hardhat test tests/test-blockchain-flow.ts",
    "compile": "hardhat compile",
    "node": "hardhat node",
    "demo:local": "hardhat run scripts/demo.ts --network localhost",
    "demo:amoy": "ts-node scripts/demo.ts --network amoy",
    "show-certificate:local": "ts-node scripts/show-certificate.ts --network localhost",
    "test:v2": "ts-node tests/test-v2-telemetry.ts"
  },
  "keywords": [
    "c2pa",
    "provenance",
    "blockchain",
    "ipfs",
    "human-is-kind"
  ],
  "author": "",
  "license": "SEE LICENSE IN README.md",
  "dependencies": {
    "@types/cbor": "^5.0.1",
    "@types/node-forge": "^1.3.14",
    "axios": "^1.6.0",
    "cbor": "^10.0.12",
    "ethers": "^6.9.0",
    "json-stable-stringify": "^1.3.0",
    "node-forge": "^1.3.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@types/node": "^20.10.0",
    "dotenv": "^16.3.1",
    "hardhat": "^2.19.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0"
  }
}
